{
  "name": "obsidian-queue",
  "version": "0.1.0",
  "description": "Agent task queue + state machine for Obsidian (node:sqlite, REST + CLI, Kanban/DAG board)",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "npm run build && node --test test/service.test.mjs",
    "test:bundle": "npm run build && node test/bundle-smoke.cjs"
  },
  "keywords": [
    "obsidian-plugin",
    "agents",
    "task-queue",
    "state-machine"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.7",
    "esbuild": "^0.21.5",
    "obsidian": "^1.5.0",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  }
}
